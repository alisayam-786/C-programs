#include <stdio.h>

#define MAX 100


void menu();
void inputArray(int arr[], int *n);
int sumArray(int arr[], int n);
float averageArray(int arr[], int n);
int minArray(int arr[], int n);
int maxArray(int arr[], int n);
void displayArray(int arr[], int n);

int main() {
    int arr[MAX];
    int n = 0;
    int choice;

    do {
        menu();
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                inputArray(arr, &n);
                break;
            case 2:
                printf("Sum of elements = %d\n", sumArray(arr, n));
                break;
            case 3:
                printf("Average of elements = %.2f\n", averageArray(arr, n));
                break;
            case 4:
                printf("Minimum element = %d\n", minArray(arr, n));
                break;
            case 5:
                printf("Maximum element = %d\n", maxArray(arr, n));
                break;
            case 6:
                displayArray(arr, n);
                break;
            case 7:
                printf("Exiting program...\n");
                break;
            default:
                printf("Invalid choice!\n");
        }

    } while(choice != 7);

    return 0;
}


void menu() {
    printf("\n===== ARRAY OPERATIONS MENU =====\n");
    printf("1. Input Array\n");
    printf("2. Sum of Elements\n");
    printf("3. Average of Elements\n");
    printf("4. Minimum Element\n");
    printf("5. Maximum Element\n");
    printf("6. Display Array\n");
    printf("7. Exit\n");
}


void inputArray(int arr[], int *n) {
    printf("Enter number of elements: ");
    scanf("%d", n);

    for(int i = 0; i < *n; i++) {
        printf("Element %d: ", i + 1);
        scanf("%d", &arr[i]);
    }
}


int sumArray(int arr[], int n) {
    int sum = 0;
    for(int i = 0; i < n; i++) {
        sum += arr[i];
    }
    return sum;
}


float averageArray(int arr[], int n) {
    if(n == 0) return 0;
    return (float)sumArray(arr, n) / n;
}


int minArray(int arr[], int n) {
    int min = arr[0];
    for(int i = 1; i < n; i++) {
        if(arr[i] < min)
            min = arr[i];
    }
    return min;
}


int maxArray(int arr[], int n) {
    int max = arr[0];
    for(int i = 1; i < n; i++) {
        if(arr[i] > max)
            max = arr[i];
    }
    return max;
}


void displayArray(int arr[], int n) {
    printf("Array elements are: ");
    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");
}
